# Byte-compiled / cache
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Data (large/raw files - track via project storage, not git)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Results / outputs
results/*
!results/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment variables
.env
