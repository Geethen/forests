# Byte-compiled / cache
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Data (large/raw files - track via project storage, not git)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Extraction outputs (large parquet + DuckDB buffer + resume checkpoint)
data/*.parquet
data/*.duckdb
data/*.checkpoint.json

# Results / outputs
results/*
!results/.gitkeep

# Logs
logs/
*.log

# Node / dashboard build artifacts
node_modules/
app/dist/
.vite/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment variables
.env
